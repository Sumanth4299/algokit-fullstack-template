{
  "name": "smart_contracts",
  "version": "1.0.0",
  "description": "Smart contract deployer",
  "main": "smart_contracts/index.ts",
  "type": "module",
  "scripts": {
    "build": "algokit compile ts smart_contracts --output-source-map --out-dir artifacts && algokit generate client smart_contracts/artifacts --output {app_spec_dir}/{contract_name}Client.ts",
    "deploy": "tsx watch -r dotenv/config smart_contracts/index.ts",
    "deploy:ci": "tsx -r dotenv/config smart_contracts/index.ts",
    "check-types": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0",
    "npm": ">=9.0"
  },
  "dependencies": {
    "@algorandfoundation/algorand-typescript": "^1.0.1"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-client-generator": "^7.0.0-alpha.5",
    "@algorandfoundation/algokit-utils": "^10.0.0-alpha.40",
    "@algorandfoundation/algokit-utils-debug": "^2.0.0-alpha.2",
    "@algorandfoundation/puya-ts": "^1.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tsconfig/node22": "^22.0.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
